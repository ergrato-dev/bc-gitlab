#!/bin/bash
# gl-epti-health — Verifica estado del lab GitLab CE
set -euo pipefail

echo "=== gl-epti Lab Status ==="
echo ""

# GitLab services
if gitlab-ctl status &>/dev/null; then
    echo "[OK] GitLab services running"
    gitlab-ctl status 2>/dev/null | while read -r line; do
        printf "     %s\n" "$line"
    done
else
    echo "[FAIL] GitLab services down"
fi

echo ""

# Rails check
if gitlab-rake gitlab:check 2>/dev/null | grep -q 'Checking.*finished'; then
    echo "[OK] GitLab Rails health"
else
    echo "[WARN] GitLab Rails check incomplete"
fi

echo ""

# Disk usage
echo "--- Disk ---"
df -h /var/opt/gitlab /etc/gitlab /var/log/gitlab 2>/dev/null | tail -n +2

echo ""
echo "--- Memory ---"
free -h | grep 'Mem:'
