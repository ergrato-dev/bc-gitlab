#!/bin/bash
# gl-epti-reset — Reinicia configuración de GitLab (útil para labs)
# USO: docker compose -f docker-compose.gl-epti.yml exec gl-epti gl-epti-reset

echo "=== gl-epti Reset ==="
echo "Esto reinicia la configuracion de GitLab sin borrar datos."
echo ""

gitlab-ctl reconfigure
gitlab-ctl restart

echo ""
echo "[DONE] GitLab reconfigurado y reiniciado."
echo "Verifica con: docker compose -f docker-compose.gl-epti.yml logs -f gl-epti"
