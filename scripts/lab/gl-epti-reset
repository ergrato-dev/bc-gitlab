#!/bin/bash
# gl-epti-reset — Reinicia configuracion de GitLab (util para labs)
# USO: docker compose -f docker-compose.gl-epti.yml exec gl-epti gl-epti-reset
set -euo pipefail

echo "=== gl-epti Reset ==="
echo "Reconfigurando y reiniciando GitLab sin borrar datos."
echo ""

gitlab-ctl reconfigure
gitlab-ctl restart

echo ""
echo "[DONE] GitLab reconfigurado y reiniciado."
echo "Verifica con: gl-epti-health"
