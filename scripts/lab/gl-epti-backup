#!/bin/bash
# gl-epti-backup — Backup rápido del lab
set -euo pipefail

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_DIR=${1:-/var/opt/gitlab/backups}

echo "=== gl-epti Backup ==="
echo "Timestamp: ${TIMESTAMP}"
echo ""

gitlab-backup create STRATEGY=copy

echo ""
echo "[DONE] Backup created in ${BACKUP_DIR}"
ls -lh "${BACKUP_DIR}"/*gitlab_backup* 2>/dev/null | tail -1
