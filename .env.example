# ============================================
# Bootcamp GitLab CE — Variables de entorno
# Copiar a .env y ajustar segun necesidad
#
# PRIVACIDAD: Todas las opciones de telemetria
# estan deshabilitadas por defecto en docker-compose.yml
# (usage_ping, sentry, snowplow, google_analytics)
# ============================================

# GitLab CE
GITLAB_VERSION=17-latest
GITLAB_HOST=gitlab.local
GITLAB_EXTERNAL_URL=http://localhost
GITLAB_HTTP_PORT=80
GITLAB_HTTPS_PORT=443
GITLAB_SSH_PORT=2224
GITLAB_ROOT_PASSWORD=ChangeMe123!

# GitLab Runner
RUNNER_VERSION=alpine-latest

# Docker Hub (opcional — para evitar rate limits en registry cache)
DOCKER_HUB_USER=
DOCKER_HUB_TOKEN=

# Registry cache
REGISTRY_CACHE_PORT=5000

# Prometheus (profile: monitoring)
PROMETHEUS_VERSION=latest
PROMETHEUS_PORT=9090

# Grafana (profile: monitoring)
GRAFANA_VERSION=latest
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
